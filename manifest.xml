<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="MailApp">
<Id>acdc1234-5678-4321-bcde-f123456789ab</Id>
<Version>1.0.0.1</Version>
<ProviderName>MyDevName</ProviderName>
<DefaultLocale>en-US</DefaultLocale>
<DisplayName DefaultValue="Email Prompt Tool"/>
<Description DefaultValue="Inserts custom input into a template."/>
<IconUrl DefaultValue="https://res.cdn.office.net/assets/mail/pwa/v1/pngs/apple-touch-icon.png"/>
<HighResolutionIconUrl DefaultValue="https://res.cdn.office.net/assets/mail/pwa/v1/pngs/apple-touch-icon.png"/>
<SupportUrl DefaultValue="https://octokid12.github.io/Outlook/"/>
<Hosts>
<Host Name="Mailbox"/>
</Hosts>
<Requirements>
<Sets>
<Set Name="Mailbox" MinVersion="1.3"/>
</Sets>
</Requirements>
<FormSettings>
<Form xsi:type="ItemEdit">
<DesktopSettings>
<SourceLocation DefaultValue="https://octokid12.github.io/Outlook/index.html"/>
</DesktopSettings>
</Form>
</FormSettings>
<Permissions>ReadWriteItem</Permissions>
<Rule xsi:type="RuleCollection" Mode="And">
<Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
</Rule>
<DisableEntityHighlighting>false</DisableEntityHighlighting>
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
<Requirements>
<bt:Sets DefaultMinVersion="1.3">
<bt:Set Name="Mailbox"/>
</bt:Sets>
</Requirements>
<Hosts>
<Host xsi:type="MailHost">
<DesktopFormFactor>
<FunctionFile resid="Commands.Url"/>
<ExtensionPoint xsi:type="MessageComposeCommandSurface">
<OfficeTab id="TabDefault">
<Group id="msgComposeGroup">
<Label resid="GroupLabel"/>
<Control xsi:type="Button" id="msgComposeOpenPaneButton">
<Label resid="TaskpaneButton.Label"/>
<Supertip>
<Title resid="TaskpaneButton.Label"/>
<Description resid="TaskpaneButton.Tooltip"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="80" resid="Icon.80x80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<SourceLocation resid="Taskpane.Url"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
</Hosts>
<Resources>
<bt:Images>
<bt:Image id="Icon.16x16" DefaultValue="https://res.cdn.office.net/assets/mail/pwa/v1/pngs/apple-touch-icon.png"/>
<bt:Image id="Icon.32x32" DefaultValue="https://res.cdn.office.net/assets/mail/pwa/v1/pngs/apple-touch-icon.png"/>
<bt:Image id="Icon.80x80" DefaultValue="https://res.cdn.office.net/assets/mail/pwa/v1/pngs/apple-touch-icon.png"/>
</bt:Images>
<bt:Urls>
<bt:Url id="Commands.Url" DefaultValue="https://octokid12.github.io/Outlook/index.html"/>
<bt:Url id="Taskpane.Url" DefaultValue="https://octokid12.github.io/Outlook/index.html"/>
</bt:Urls>
<bt:ShortStrings>
<bt:String id="GroupLabel" DefaultValue="Email Prompt Tool"/>
<bt:String id="TaskpaneButton.Label" DefaultValue="Generate Email"/>
</bt:ShortStrings>
<bt:LongStrings>
<bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Email Prompt Tool to generate a templated email."/>
</bt:LongStrings>
</Resources>
</VersionOverrides>
</OfficeApp>
